{
  "name": "@pug-sh/node",
  "version": "0.0.2",
  "description": "Pug server-side SDK for Node.js — event tracking, profile identify, and analytics reads.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://pug.sh",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pug-sh/sdk-node.git"
  },
  "bugs": {
    "url": "https://github.com/pug-sh/sdk-node/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "echo \"export const SDK_VERSION = '$(node -p \"require('./package.json').version\")'\" > src/version.ts",
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "watch": "tsc -w",
    "lint": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.0",
    "@bufbuild/protovalidate": "^1.1.1",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-node": "^2.1.1",
    "uuidv7": "^1.1.0"
  },
  "keywords": [
    "analytics",
    "tracking",
    "sdk",
    "pug"
  ],
  "author": "pug.sh",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@bufbuild/protoc-gen-es": "^2.12.1",
    "@types/node": "^20.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  }
}
